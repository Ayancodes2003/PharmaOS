# Runtime
APP_ENV=local
APP_NAME=pharma-os
APP_VERSION=0.1.0
APP_DEBUG=false
LOG_LEVEL=INFO

# API
API_V1_PREFIX=/api/v1
API_HOST=0.0.0.0
API_PORT=8000

# PostgreSQL
POSTGRES_URL=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pharma_os
POSTGRES_USER=pharma_admin
POSTGRES_PASSWORD=pharma_admin

# MongoDB
MONGO_URL=
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=pharma_os
MONGO_USER=pharma_admin
MONGO_PASSWORD=pharma_admin
MONGO_AUTH_SOURCE=admin

# Model and artifact locations
ARTIFACT_ROOT=./artifacts
MODEL_REGISTRY_PATH=./artifacts/models
METRICS_PATH=./artifacts/metrics
REPORTS_PATH=./artifacts/reports

# Data locations
DATA_RAW_PATH=./data/raw
DATA_PROCESSED_PATH=./data/processed
DATA_LOAD_READY_PATH=./data/load_ready
DATA_FEATURE_READY_PATH=./data/feature_ready
DATA_FEATURE_STORE_PATH=./data/feature_store
DATA_ANALYTICS_MARTS_PATH=./data/analytics_marts
DATA_SOURCE_PATH=./data/source
PATIENTS_SOURCE_PATH=
TRIALS_SOURCE_PATH=
ADVERSE_EVENTS_SOURCE_PATH=
DRUG_EXPOSURES_SOURCE_PATH=
PHASE5_REPORTS_PATH=./artifacts/reports/phase5
PHASE6_REPORTS_PATH=./artifacts/reports/phase6
PHASE7_REPORTS_PATH=./artifacts/reports/phase7

# AI/LLM
LLM_PROVIDER=
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=
